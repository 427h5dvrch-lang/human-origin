{
  "name": "human-origin",
  "private": true,
  "version": "0.1.16",
  "type": "module",
  "scripts": {
    "dev": "vite --port 1420 --strictPort",
    "build": "vite build --base=./",
    "preview": "vite preview",
    "tauri": "tauri",
    "bump": "node bump_version.mjs",
    "bump:git": "node bump_version.mjs --git --tag",
    "bump:git:cargo": "node bump_version.mjs --git --tag --cargo",
    "build:mac-app": "npm run build && tauri build --bundles app",
    "install:mac-app": "rm -rf /Applications/HumanOrigin.app && ditto src-tauri/target/release/bundle/macos/HumanOrigin.app /Applications/HumanOrigin.app",
    "run:mac-app": "open /Applications/HumanOrigin.app",
    "refresh:mac-app": "pkill -f HumanOrigin || true && pkill -f human-origin || true && npm run build:mac-app && npm run install:mac-app && npm run run:mac-app"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "@tauri-apps/api": "^1.5.3",
    "fflate": "^0.8.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.9",
    "vite": "^5.0.12"
  }
}
