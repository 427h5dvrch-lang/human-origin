{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "HumanOrigin",
    "version": "0.1.20"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "all": true
      },
      "shell": {
        "all": false,
        "open": true,
        "execute": true,
        "scope": [
          {
            "name": "binaries/humanorigin-publisher",
            "sidecar": true,
            "args": true
          },
          {
            "name": "binaries/humanorigin-publisher",
            "sidecar": true,
            "args": [
              "--job",
              {
                "validator": ".+"
              }
            ]
          },
          {
            "name": "binaries/humanorigin-converter",
            "sidecar": true,
            "args": true
          }
        ],
        "sidecar": true
      },
      "dialog": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": [
          "https://*.supabase.co/*"
        ]
      },
      "fs": {
        "all": true,
        "scope": [
          "$APP/**",
          "$DOCUMENT/**",
          "$RESOURCE/**",
          "$TEMP/**",
          "$DOWNLOAD/**",
          "$HOME/**",
          "$APPDATA/**",
          "$LOCALDATA/**",
          "$DESKTOP/**",
          "C:/Users/**",
          "C:/Users/**/Documents/**",
          "C:/Users/**/Downloads/**",
          "C:/Users/**/Desktop/**",
          "C:/Mac/Home/**",
          "C:/Mac/Home/Documents/**",
          "C:/Mac/Home/Downloads/**",
          "C:/Mac/Home/Desktop/**"
        ]
      },
      "path": {
        "all": true
      },
      "protocol": {
        "all": true
      },
      "process": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.humanorigin.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "externalBin": [
        "binaries/humanorigin-publisher",
        "binaries/humanorigin-converter"
      ],
      "category": "DeveloperTool",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      }
    },
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: asset: filesystem: ws: wss: https: http:; img-src 'self' data: blob: asset: https: http:; style-src 'self' 'unsafe-inline' data: blob: asset: https: http:; font-src 'self' data: blob: asset: https: http:; frame-src 'self' data: blob: asset:;"
    },
    "updater": {
      "active": true,
      "dialog": true,
      "endpoints": [
        "https://github.com/427h5dvrch-lang/human-origin/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCMkFEMzI3RkFFRTJFNwpSV1RuNHE1L01xMnlDRUNZcTU1bG5NZXZMaGFvWTBkUzgwTXhuWWZ2YjBmS2gyUDM4eFB0OUZMMQo="
    },
    "windows": [
      {
        "title": "HumanOrigin",
        "width": 900,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ]
  }
}
